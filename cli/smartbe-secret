#!/usr/bin/env bash
set -euo pipefail

# SmartBe Secrets CLI — resolve a secret from the control plane
# Usage: smartbe-secret KEY_NAME

CONFIG_PATH="${SMARTBE_CONFIG_PATH:-/opt/openclaw/.control-plane-secrets.env}"

if [[ $# -lt 1 ]]; then
  echo "Usage: smartbe-secret KEY_NAME" >&2
  exit 1
fi

KEY="$1"

# Fallback: check environment variable directly
if [[ -n "${!KEY:-}" ]]; then
  printf '%s' "${!KEY}"
  exit 0
fi

# Read control-plane config
if [[ ! -f "$CONFIG_PATH" ]]; then
  echo "Error: Config not found at $CONFIG_PATH" >&2
  echo "Set SMARTBE_CONFIG_PATH or ensure the SDK config is mounted." >&2
  exit 1
fi

# Source the config (sets OPENCLAW_CONTROL_PLANE_BASE_URL, _JOB_ID, _TOKEN)
set -a
source "$CONFIG_PATH"
set +a

BASE_URL="${OPENCLAW_CONTROL_PLANE_BASE_URL:?Missing OPENCLAW_CONTROL_PLANE_BASE_URL}"
JOB_ID="${OPENCLAW_CONTROL_PLANE_JOB_ID:?Missing OPENCLAW_CONTROL_PLANE_JOB_ID}"
TOKEN="${OPENCLAW_CONTROL_PLANE_TOKEN:?Missing OPENCLAW_CONTROL_PLANE_TOKEN}"

# Resolve the secret via control plane
RESPONSE=$(curl -sf \
  -X POST \
  -H "Content-Type: application/json" \
  -H "X-OpenClaw-Callback-Secret: ${TOKEN}" \
  -d "{\"protocolVersion\":1,\"ids\":[\"${KEY}\"]}" \
  "${BASE_URL}/api/claw/${JOB_ID}/runtime-secrets/resolve" \
  2>/dev/null) || {
  echo "Error: Failed to resolve secret '${KEY}' from control plane" >&2
  exit 1
}

# Extract value (simple JSON parsing — jq if available, else python/node fallback)
if command -v jq &>/dev/null; then
  VALUE=$(echo "$RESPONSE" | jq -re ".values.\"${KEY}\" // empty" 2>/dev/null)
elif command -v python3 &>/dev/null; then
  VALUE=$(echo "$RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); v=d.get('values',{}).get('${KEY}',''); print(v,end='')" 2>/dev/null)
elif command -v node &>/dev/null; then
  VALUE=$(echo "$RESPONSE" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);process.stdout.write(j.values?.['${KEY}']||'')})" 2>/dev/null)
else
  echo "Error: Need jq, python3, or node to parse response" >&2
  exit 1
fi

if [[ -z "$VALUE" ]]; then
  echo "Error: Secret '${KEY}' not found" >&2
  exit 1
fi

printf '%s' "$VALUE"
