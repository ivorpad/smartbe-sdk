#!/usr/bin/env bash
set -euo pipefail

# SmartBe skill wrapper — ensures SDK is available and runs the skill script.

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"

# Make SmartBe Python SDK available to uv's isolated venv
export PYTHONPATH="${PYTHONPATH:-}:/usr/lib/python3/dist-packages"

exec uv run "${SKILL_DIR}/scripts/generate_image.py" "$@"
